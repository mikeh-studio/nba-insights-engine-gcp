GCP_PROJECT_ID=your_gcp_project
BQ_PROJECT=your_gcp_project
GCS_BUCKET_NAME=your_gcs_bucket
BQ_DATASET_BRONZE=nba_bronze
BQ_DATASET_SILVER=nba_silver
BQ_DATASET_GOLD=nba_gold
BQ_METADATA_DATASET=nba_metadata
BQ_LOCATION=US
NBA_MAX_PLAYERS=0
NBA_REPLAY_DAYS=3
DBT_TARGET=dev
API_FRESHNESS_THRESHOLD_HOURS=36
PORT=8080
AIRFLOW_HOME=./airflow_home

# --- Redshift (optional, secondary warehouse) ---
ENABLE_REDSHIFT=false
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-nba-redshift-landing
REDSHIFT_HOST=your-workgroup.123456.us-east-1.redshift-serverless.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=nba_analytics
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=your_password
REDSHIFT_IAM_ROLE_ARN=arn:aws:iam::123456789012:role/nba-analytics-redshift-s3
REDSHIFT_SCHEMA_BRONZE=nba_bronze
REDSHIFT_SCHEMA_SILVER=nba_silver
REDSHIFT_SCHEMA_GOLD=nba_gold
